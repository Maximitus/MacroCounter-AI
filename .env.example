# GEMINI_API_KEY: Set as a secret in Cloudflare (Pages project → Settings → Variables).
# The app calls /macrocounter/api/chat; the Pages Function attaches this key server-side.
# Local full-stack: npx wrangler pages dev -- npm run dev

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
